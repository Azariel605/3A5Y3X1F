<Window x:Class="e45y3x1f._m41nw1nd0w"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Easy EXIF - Easy EXIF Metadata Tool" Height="600" Width="800"
        Background="#FFF4EA"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF4EA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Title Bar -->
        <StackPanel Grid.Row="0" Margin="20">
            <TextBlock Text="Easy EXIF - Easy EXIF Metadata Tool"
                       FontSize="32"
                       Foreground="#B8142D"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,10"/>
            <TextBlock Text="The core system is ready for implementation"
                       FontSize="14"
                       Foreground="#D3CBC3"
                       TextAlignment="Center"/>
        </StackPanel>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel: Image and Metadata -->
            <Grid Grid.Column="0" Margin="20,0,10,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                
                <!-- Image Preview Section -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" BorderThickness="2" BorderBrush="#D3CBC3">
                    <Grid>
                        <Image Name="ImagePreview"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        <TextBlock Name="NoImageText"
                                   Text="No image selected&#10;Click 'Select Image' to begin"
                                   FontSize="16"
                                   Foreground="#D3CBC3"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- Splitter -->
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#D3CBC3"/>
                
                <!-- EXIF Metadata Section -->
                <Border Grid.Row="2" Background="White" CornerRadius="8" BorderThickness="2" BorderBrush="#D3CBC3" Margin="0,5,0,0">
                    <Grid>
                        <TextBlock Name="NoMetadataText"
                                   Text="No EXIF data to display&#10;Select an image and click 'View EXIF'"
                                   FontSize="12"
                                   Foreground="#D3CBC3"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBox Name="ExifMetadataBox"
                                 Background="White"
                                 Foreground="#333333"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Padding="10"
                                 FontSize="11"
                                 FontFamily="Consolas"
                                 Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Controls Panel -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,20,20,20" MaxHeight="550">
                <!-- Exiftool Options Section -->
                <TextBlock Text="Exiftool Options"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#B8142D"
                           Margin="0,0,0,5"/>
                
                <TextBox Name="ExiftoolOptionsBox"
                         Background="White"
                         Foreground="#333333"
                         BorderBrush="#D3CBC3"
                         BorderThickness="1"
                         Padding="8"
                         FontSize="10"
                         FontFamily="Consolas"
                         Height="60"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,10"
                         Text="-json -a -G -ee"/>
                
                <TextBlock Text="Example: -json -a -G -ee -n"
                           FontSize="9"
                           Foreground="#D3CBC3"
                           Margin="0,-5,0,10"/>
                
                <!-- Main Function Buttons -->
                <Button Name="SelectImageButton"
                        Content="📁 Select Image"
                        Click="SelectImageButton_Click"
                        Foreground="White"
                        Background="#B8142D"
                        FontSize="14"
                        Padding="15,12"
                        Margin="0,0,0,10"
                        Cursor="Hand"/>
                
                <Button Name="ViewExifButton"
                        Content="🔍 View/Edit EXIF"
                        Click="ViewExifButton_Click"
                        Foreground="White"
                        Background="#B8142D"
                        FontSize="14"
                        Padding="15,12"
                        Margin="0,0,0,10"
                        Cursor="Hand"/>
                
                <Button Name="AddMetadataButton"
                        Content="➕ Add Metadata"
                        Click="AddMetadataButton_Click"
                        Foreground="White"
                        Background="#B8142D"
                        FontSize="14"
                        Padding="15,12"
                        Margin="0,0,0,10"
                        Cursor="Hand"/>
                
                <Button Name="CompressImageButton"
                        Content="🗜️ Compress Image"
                        Click="CompressImageButton_Click"
                        Foreground="White"
                        Background="#B8142D"
                        FontSize="14"
                        Padding="15,12"
                        Margin="0,0,0,10"
                        Cursor="Hand"/>
                
                <Button Name="CheckUpdatesButton"
                        Content="⚙️ Check for Updates"
                        Click="CheckUpdatesButton_Click"
                        Foreground="White"
                        Background="#8B0D23"
                        FontSize="12"
                        Padding="15,10"
                        Margin="0,0,0,10"
                        Cursor="Hand"/>
                
                <Button Name="RemoveImageButton"
                        Content="❌ Remove Image"
                        Click="RemoveImageButton_Click"
                        Foreground="White"
                        Background="#D3CBC3"
                        FontSize="12"
                        Padding="15,10"
                        Margin="0,0,0,0"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="e45y3x1f.mobile.MainPage"
             Title="Easy EXIF - Mobile">
    
    <VerticalStackLayout Spacing="10" Padding="15">
        
        <!-- Header -->
        <Label Text="Easy EXIF Mobile" FontSize="24" FontAttributes="Bold"/>
        <Label Text="Extract and view image metadata" FontSize="14"/>

        <!-- Image Selection -->
        <HorizontalStackLayout Spacing="10">
            <Label Text="No image selected" x:Name="ImageStatusLabel" VerticalTextAlignment="Center" FontSize="14"/>
            <Button Text="Select Image" Clicked="OnSelectImage"/>
        </HorizontalStackLayout>

        <!-- EXIF Data Display -->
        <Label Text="Extracted EXIF Data" FontSize="14" FontAttributes="Bold"/>
        <Editor x:Name="ExifDataEditor"
                IsReadOnly="True"
                HeightRequest="200"
                FontSize="12"
                Text="[Select an image and click View EXIF to extract metadata]"/>

        <!-- Action Buttons -->
        <HorizontalStackLayout Spacing="8">
            <Button Text="View EXIF" Clicked="OnViewExif" HorizontalOptions="FillAndExpand"/>
            <Button Text="Clear" Clicked="OnClear" HorizontalOptions="FillAndExpand"/>
        </HorizontalStackLayout>
        
    </VerticalStackLayout>

</ContentPage>
